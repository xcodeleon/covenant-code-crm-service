# Production environment variables
# Copy to .env and fill in real values before deploying to swarm
# Deploy: export $(cat .env | xargs) && docker stack deploy -c docker-stack.yml crm

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=crm_db
DB_USER=crm_user
DB_PASSWORD=change_me

# JWT — минимум 32 символа для HS256
JWT_SECRET=change_me_to_a_secure_random_256_bit_secret
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Server
SERVER_PORT=8080

# Docker registry
REGISTRY=registry.example.com
IMAGE_TAG=latest
